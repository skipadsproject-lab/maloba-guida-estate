:root{--sage:#c8d8a0;--paper:#f7f4ed;--ink:#2e3d1a;--blue:#1e3e8c;--blue2:#2b52b8;--pink:#ea8a86;--pink2:#f5c4c2}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Montserrat',Arial,sans-serif;background:var(--sage);color:var(--ink);line-height:1.6}
.cover{background:var(--sage);min-height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.ci{position:relative;z-index:2;max-width:820px;width:100%;margin:0 auto;padding:60px 36px 80px}
.dots{position:absolute;top:40px;right:40px;display:flex;gap:14px;z-index:3}
.dots span{width:18px;height:18px;border:4px solid rgba(255,255,255,.85);border-radius:50%;display:block}
.bptl{position:absolute;top:-70px;left:60px;width:210px;height:210px;background:var(--pink);border-radius:50%;z-index:1}
.bpbr{position:absolute;bottom:-80px;right:-40px;width:270px;height:270px;background:var(--pink);border-radius:50%;z-index:1}
.rtl{position:absolute;top:-60px;left:-60px;width:250px;height:250px;z-index:1}
.rbr{position:absolute;bottom:-50px;right:-20px;width:230px;height:230px;z-index:2}
.rtl circle,.rbr circle{fill:none;stroke:var(--blue2);stroke-width:6}
.brand{font-weight:900;font-size:13px;letter-spacing:.22em;text-transform:uppercase;margin-bottom:20px;color:var(--blue)}
h1{font-weight:900;font-size:clamp(40px,8vw,86px);line-height:.92;text-transform:uppercase;margin-bottom:24px}
.csub{font-size:clamp(15px,2vw,20px);font-weight:700;text-transform:uppercase;line-height:1.25;max-width:24ch;margin-bottom:38px}
.carr{font-size:36px;margin-top:8px}
.bw{background:var(--paper)}
.torn{width:100%;display:block;margin-top:-1px}
.sec{max-width:820px;margin:0 auto;padding:16px 36px 64px}
.chapter{margin-bottom:48px}
.chapter-title{font-weight:900;font-size:clamp(18px,3vw,26px);text-transform:uppercase;color:var(--blue);margin-bottom:18px;display:flex;align-items:center;gap:10px;border-bottom:3px solid var(--pink);padding-bottom:10px}
.num{background:var(--pink);color:white;border-radius:50%;width:34px;height:34px;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:900;flex-shrink:0}
.card{background:rgba(255,253,246,.7);border:1px solid rgba(46,61,26,.1);border-radius:18px;padding:20px 20px;margin-bottom:14px;box-shadow:0 4px 18px rgba(46,61,26,.06)}
.card h3{font-weight:900;font-size:18px;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.card p{font-size:16px;max-width:64ch;color:var(--ink)}
.highlight{background:var(--sage);border-radius:14px;padding:16px 18px;margin:14px 0;font-size:16px;font-weight:700}
.tip{background:rgba(234,138,134,.15);border-left:4px solid var(--pink);border-radius:0 12px 12px 0;padding:14px 18px;margin:14px 0;font-size:16px}
.tbl-wrap{overflow-x:auto;margin:14px 0}
table{width:100%;border-collapse:collapse;font-size:15px}
th{background:var(--blue);color:white;padding:11px 14px;text-align:left;font-weight:700;font-size:13px;letter-spacing:.08em;text-transform:uppercase}
td{padding:11px 14px;border-bottom:1px solid rgba(46,61,26,.1)}
tr:nth-child(even) td{background:rgba(200,216,160,.25)}
tr:last-child td{border-bottom:none}
.food-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:14px;margin-top:14px}
.food-card{background:rgba(255,253,246,.8);border-radius:16px;padding:18px 16px;border:1px solid rgba(46,61,26,.09);box-shadow:0 3px 12px rgba(46,61,26,.05)}
.food-card .icon{font-size:32px;margin-bottom:8px}
.food-card h4{font-weight:900;font-size:16px;margin-bottom:6px}
.food-card p{font-size:14px;opacity:.85}
.rule{background:linear-gradient(135deg,rgba(200,216,160,.6),rgba(245,196,194,.4));border-radius:18px;padding:20px 22px;margin-bottom:14px;display:flex;gap:14px;align-items:flex-start}
.rule-star{font-size:22px;flex-shrink:0;margin-top:2px}
.rule h4{font-weight:900;font-size:17px;margin-bottom:6px;color:var(--blue)}
.rule p{font-size:15px}
.closing{background:var(--sage);border-radius:20px;padding:28px 26px;margin-top:16px;text-align:center}
.closing p{font-size:clamp(18px,2.5vw,24px);font-weight:700;line-height:1.4;max-width:30ch;margin:0 auto 10px}
.closing small{font-size:13px;opacity:.7;letter-spacing:.1em;text-transform:uppercase}
.sf{background:var(--sage);padding:44px 36px 54px;text-align:center}
.brand-footer{font-family:'Montserrat',sans-serif;font-weight:900;font-size:22px;color:var(--blue);letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px}
.brand-footer span{color:var(--pink);font-style:italic;font-size:16px;font-weight:700;display:block;letter-spacing:.04em}
.sf h4{font-weight:900;font-size:13px;letter-spacing:.18em;text-transform:uppercase;margin:16px 0 18px;color:var(--ink)}
.sl{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:20px}
.sl a{display:flex;align-items:center;gap:8px;background:white;color:var(--ink);text-decoration:none;font-weight:700;font-size:13px;padding:10px 18px;border-radius:999px;box-shadow:0 3px 10px rgba(46,61,26,.1);transition:transform .18s}
.sl a:hover{transform:translateY(-2px)}
.sl a svg{width:18px;height:18px;flex-shrink:0}
.wa{background:#25d366!important;color:white!important}
.tl{font-size:12px;opacity:.65;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-top:8px}
@media(max-width:660px){
  .ci,.sec{padding-left:18px;padding-right:18px}
